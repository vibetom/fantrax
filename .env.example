# Fantrax settings
FANTRAX_USER_SECRET_ID=your_secret_id_from_fantrax_profile
FANTRAX_LEAGUE_ID=your_league_id

# Fantrax session cookie (required for detailed player stats, transactions, matchups)
# To get this: log into fantrax.com, open DevTools (F12) → Application → Cookies
# → fantrax.com → copy the value of JSESSIONID
FANTRAX_JSESSIONID=your_jsessionid_cookie_value

# Anthropic (for AI commentary generation)
ANTHROPIC_API_KEY=your_anthropic_api_key
