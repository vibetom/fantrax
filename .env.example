# Fantrax settings
FANTRAX_USER_SECRET_ID=your_secret_id_from_fantrax_profile
FANTRAX_LEAGUE_ID=your_league_id

# Fantrax session cookies (required for detailed player stats, transactions, matchups)
# To get these: log into fantrax.com, open DevTools (F12) → Application → Cookies → fantrax.com
# FX_RM is the critical "remember me" cookie. JSESSIONID is the session cookie.
# Set whichever you can find (FX_RM is most important):
FANTRAX_FX_RM=your_fx_rm_cookie_value
FANTRAX_JSESSIONID=your_jsessionid_cookie_value
# Or paste all cookies as one string:
# FANTRAX_COOKIES=FX_RM=abc123; JSESSIONID=xyz789

# Anthropic (for AI commentary generation)
ANTHROPIC_API_KEY=your_anthropic_api_key
